    "    sqft[0] = 2800; price[0] = 450000\n",
    "    sqft[1] = 1250; price[1] = 440000\n",
    "    sqft[2] = 3250; price[2] = 390000\n",
    "    sqft[3] = 900;  price[3] = 500000\n",
    "    price = np.clip(price, 80000, None)\n",
    "    over_budget = (price >= BUDGET).astype(int)\n",
    "    return sqft, price, over_budget\n",
